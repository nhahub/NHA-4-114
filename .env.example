# ── Smart Vision System — Environment Variables ───────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in values below (especially change passwords in production)
#   3. Never commit .env to git — it is in .gitignore
#
# In Docker: docker-compose.yml reads this file via env_file: .env
# In Python: pydantic-settings reads it automatically via config.py
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# Used by: FastAPI backend, Celery workers, Alembic migrations
# Format:  postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
POSTGRES_URL=postgresql+asyncpg://svs:svs@postgres:5432/svs

# Used by: docker-compose.prod.yml (passed separately to the postgres container)
POSTGRES_USER=svs
POSTGRES_PASSWORD=svs
POSTGRES_DB=svs


# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by: core/redis.py (pub/sub), Celery broker
# Format:  redis://HOST:PORT/DATABASE_INDEX
REDIS_URL=redis://redis:6379/0


# ── First superuser (created once when the users table is empty) ─────────────
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=123

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=true
HOST=0.0.0.0
PORT=3000

# Maximum frames per second sent to Redis / WebSocket clients
MAX_FPS=15

# JPEG encoding quality (1-100). Lower = smaller payload, less detail.
JPEG_QUALITY=75

# CORS — comma-separated list of allowed frontend origins
# In production change to your actual domain, e.g. https://yourdomain.com
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]


# ── AI Model ──────────────────────────────────────────────────────────────────
# Path to YOLOv8 weights file, relative to /app inside the container
MODEL_PATH=models/yolov8n.pt


# ── Object Storage (MinIO) — Phase 3 ─────────────────────────────────────────
# Used by: core/storage.py (heatmap uploads)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=svs-media


# ── Frontend (Next.js) — Phase 3 ──────────────────────────────────────────────
# These are baked into the Next.js build at compile time (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
