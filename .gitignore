# ── Smart Vision System — .gitignore ─────────────────────────────────────────

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
frontend/.env.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
venv/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── AI model weights (large binaries — store separately or in DVC) ────────────
models/*.pt
models/*.pth
models/*.onnx
!models/README.md
!models/*.py
!models/weapon_final.pt

# ── Generated / runtime data ──────────────────────────────────────────────────
backend/static/heatmaps/
data/
datasets/
*.db
*.sqlite3
weapon-detection-1/
!dataset/*.py

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── IDE / AI assistants ───────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.gemini/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Media ─────────────────────────────────────────────────────────────────────
*.mp4
*.avi
*.mov
